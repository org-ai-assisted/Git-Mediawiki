# Gateway between Git and MediaWiki.
# Documentation & bugtracker: https://github.com/Git-Mediawiki/Git-Mediawiki

use strict;
use warnings;
use lib (split(/:/, $ENV{GITPERLLIB} || ""));

use MediaWiki::API;
use Git;
use Git::Mediawiki qw(clean_filename smudge_filename connect_maybe EMPTY HTTP_CODE_OK);
use DateTime::Format::ISO8601;
use warnings;

# By default, use UTF-8 to communicate with Git and the user
binmode STDERR, ':encoding(UTF-8)';
binmode STDOUT, ':encoding(UTF-8)';

use URI::Escape;
use Time::HiRes ();

# It's not always possible to delete pages (may require some
# privileges). Deleted pages are replaced with this content.
use constant DELETED_CONTENT => "[[Category:Deleted]]\n";
# A wikitext deletion marker is INVALID in a css/javascript content-model page (it
# is served as literal css/js and breaks the wiki's combined site assets), so
# deletions of those pages use a marker valid for the model instead. The push side
# (deleted_content_for_title) picks one by title suffix; the import side
# (is_deleted_marker) MUST recognise ANY of them as a deletion -- otherwise a fetch
# re-imports the marker as ordinary content and resurrects the page. (Local fork change.)
use constant DELETED_CONTENT_CSS => "/* page removed via git-mediawiki */\n";
use constant DELETED_CONTENT_JS  => "// page removed via git-mediawiki\n";

# It's not possible to create empty pages. New empty files in Git are
# sent with this content instead.
use constant EMPTY_CONTENT => "<!-- empty page -->\n";

# It's not possible to create empty pages. New empty files in Git are
# sent with this content instead.
use constant SUPPRESSED_REVISION => "<!-- suppressed revision -->\n";

# used to reflect file creation or deletion in diff.
use constant NULL_SHA1 => '0000000000000000000000000000000000000000';

# Used on Git's side to reflect empty edit messages on the wiki
use constant EMPTY_MESSAGE => '*Empty MediaWiki Message*';

# Number of pages taken into account at once in submodule get_mw_page_list
use constant SLICE_SIZE => 50;

# Number of linked mediafile to get at once in get_linked_mediafiles
# The query is split in small batches because of the MW API limit of
# the number of links to be returned (500 links max).
use constant BATCH_SIZE => 10;

# Network-retry backoff bounds (seconds). Transient failures are retried with
# exponential backoff starting at RETRY_BACKOFF_BASE, doubling each attempt,
# capped at RETRY_BACKOFF_MAX. See mw_retry() and remote.<remote>.maxRetries.
use constant RETRY_BACKOFF_BASE => 1;
use constant RETRY_BACKOFF_MAX => 30;

# HTTP status codes that indicate a transient, retryable failure.
use constant HTTP_CODE_REQUEST_TIMEOUT => 408;
use constant HTTP_CODE_TOO_MANY_REQUESTS => 429;

if (@ARGV != 2) {
	exit_error_usage();
}

my $remotename = $ARGV[0];
my $url = $ARGV[1];

# Accept both space-separated and multiple keys in config file.
# Spaces should be written as _ anyway because we'll use chomp.
my @tracked_pages = split(/[ \n]/, run_git_quoted(["config", "--get-all", "remote.${remotename}.pages"]));
chomp(@tracked_pages);

# Just like @tracked_pages, but for MediaWiki categories.
my @tracked_categories = split(/[ \n]/, run_git_quoted(["config", "--get-all", "remote.${remotename}.categories"]));
chomp(@tracked_categories);

# Just like @tracked_categories, but for MediaWiki namespaces.
my @tracked_namespaces = split(/[ \n]/, run_git_quoted(["config", "--get-all", "remote.${remotename}.namespaces"]));
for (@tracked_namespaces) { s/_/ /g; }
chomp(@tracked_namespaces);

# Import media files on pull
my $import_media = run_git_quoted(["config", "--get", "--bool", "remote.${remotename}.mediaimport"]);
chomp($import_media);
$import_media = ($import_media eq 'true');

# Backfill File: media whose local binary is missing.
#
# Media is normally fetched only alongside a *new* File: page revision (see
# handle_result_page -> get_mw_mediafile_for_page_revision). A clone that was
# first taken with mediaimport=false imports the File: page text WITHOUT the
# binary; a later incremental fetch with mediaimport=true sees no new revision
# for those pages ("Found 0 revisions") and never backfills the binary. The
# result is File: pages present in the tree with the actual image absent.
#
# When enabled, after the normal import we enumerate every File: page on the
# wiki, check whether its binary is already present in the imported tree, and
# fetch + commit the *current* version for any that are missing. This is
# revision-agnostic on purpose: it keys off local-binary presence, not on
# whether the page has a new revision, so it heals an old mediaimport=false
# clone in place.
#
# Configurable with remote.<remotename>.backfillMedia (bool). Defaults to the
# value of mediaimport: turning media import on implies we want every File:
# page's binary, including ones a prior mediaimport=false run left behind.
my $backfill_media_cfg = run_git_quoted(["config", "--get", "--bool", "remote.${remotename}.backfillMedia"]);
chomp($backfill_media_cfg);
my $backfill_media;
if ($backfill_media_cfg eq q{}) {
	$backfill_media = $import_media;
} else {
	$backfill_media = ($backfill_media_cfg eq 'true');
}

# Export media files on push
my $export_media = run_git_quoted(["config", "--get", "--bool", "remote.${remotename}.mediaexport"]);
chomp($export_media);
$export_media = !($export_media eq 'false');

# Run-time test/debug toggles. These are deliberately ENV vars (git's own
# GIT_TRACE-style convention for per-run debug switches) rather than persistent
# remote.<remote>.* config: they belong to a single test/profiling invocation,
# not to the remote's saved settings. (Local fork change.)
#
# GIT_MEDIAWIKI_DRY_RUN: walk the full push machinery (commit pairs, diffs, file
# content) but SKIP every wiki-mutating API call -- each page edit / media upload
# is logged ("DRY-RUN: ...") and treated as a no-op success. Lets the
# reproduction's stage tests iterate without re-pushing all content every time.
# It still reports the ref as pushed ("ok") so the stage step succeeds, but writes
# NO durable mediawiki_revision note / resume checkpoint. (git itself still
# advances the remote-tracking ref on "ok", so a later run on the SAME clone sees
# "nothing to push" -- re-clone, as the reproduction does, for a fresh dry-run or
# a real push.)
my $dry_run = (($ENV{GIT_MEDIAWIKI_DRY_RUN} // q{}) =~ /^(?:1|true|yes)$/i) ? 1 : 0;
#
# GIT_MEDIAWIKI_PROFILE: time each page edit (the API round-trip) and print a
# per-push summary (count, total, mean, slowest) to stderr -- the CLIENT-side
# view of where push wall-time goes. The server-side breakdown (parse vs
# LinksUpdate vs SearchUpdate) needs MediaWiki's own profiler, separately.
my $profile = (($ENV{GIT_MEDIAWIKI_PROFILE} // q{}) =~ /^(?:1|true|yes)$/i) ? 1 : 0;
my @profile_samples;	# per-edit seconds, collected only when $profile
#
# GIT_MEDIAWIKI_PARALLEL_PUSH=N: shard each commit's files across N parallel worker
# processes (dumbPush ONLY -- last-write-wins, no per-page notes / ordering to keep).
# Each worker logs in on its OWN handle (a forked LWP/MediaWiki::API handle cannot be
# shared across processes). This speeds a server-bound bulk load, BUT N concurrent
# edits reintroduce the LinksUpdate/externallinks lock contention that a serialised
# (one-edit-at-a-time) load avoids -- deadlocks are then absorbed by the per-edit
# retry, so the net speedup depends on how often they fire. 1 (default) = serial;
# ignored for a non-dumbPush (incremental) push, which needs serial order for its
# tracking notes.
my $parallel_push = (($ENV{GIT_MEDIAWIKI_PARALLEL_PUSH} // q{}) =~ /^([1-9][0-9]*)$/) ? $1 : 1;

my $wiki_login = run_git_quoted(["config", "--get", "remote.${remotename}.mwLogin"]);
# Note: mwPassword is discouraged. Use the credential system instead.
my $wiki_passwd = run_git_quoted(["config", "--get", "remote.${remotename}.mwPassword"]);
my $wiki_domain = run_git_quoted(["config", "--get", "remote.${remotename}.mwDomain"]);
chomp($wiki_login);
chomp($wiki_passwd);
chomp($wiki_domain);

# Import only last revisions (both for clone and fetch)
my $shallow_import = run_git_quoted(["config", "--get", "--bool", "remote.${remotename}.shallow"]);
chomp($shallow_import);
$shallow_import = ($shallow_import eq 'true');

# Mid-fetch checkpointing.
#
# git-mediawiki streams every imported revision to git-fast-import, but
# fast-import only flushes its objects, the imported ref and the
# mediawiki-revision notes to disk when the stream finalises. An import
# interrupted before "done" (Ctrl-C, network drop, OOM, crash) therefore
# loses ALL uncommitted progress: the next run reads get_last_local_revision(),
# finds the note from the last *completed* fetch, and re-scans + re-imports
# everything since then. On a big wiki this re-does hours of work.
#
# Emitting fast-import's "checkpoint" command after every N imported revisions
# forces a flush of the pending objects, the refs/mediawiki/<remote>/master
# ref and the refs/notes/<remote>/mediawiki notes ref. Because
# get_last_local_revision() reads the note off the master tip, a checkpoint
# makes the just-imported revisions durable and resumable: a later run picks up
# right after the last checkpointed revision instead of from scratch.
#
# "checkpoint" is an async flush in fast-import -- it is safe to issue it after
# the commit pair it should persist; fast-import completes the in-flight commit
# before flushing.
#
# Configurable with remote.<remotename>.checkpointEvery (revisions per
# checkpoint); 0 or negative disables checkpointing. Default 100.
my $checkpoint_every = run_git_quoted(["config", "--get", "--int", "remote.${remotename}.checkpointEvery"]);
chomp($checkpoint_every);
if ($checkpoint_every eq q{}) {
	$checkpoint_every = 100;
}

# Network-retry robustness.
#
# Transient network/API failures (connection timeout/reset, DNS blip, HTTP
# 408/429/5xx, MediaWiki maxlag) must NOT kill a fetch: they are retried with
# exponential backoff. Permanent failures (HTTP 400/401/403/404, auth, a
# semantic API error) are NOT retried and fail loud immediately.
#
# Two network paths are hardened:
#  - MediaWiki API calls ($mediawiki->api/list/edit) -- MediaWiki::API has a
#    built-in retry+maxlag loop, enabled from this value in connect_maybe().
#  - Media-file downloads (download_mw_mediafile) -- a raw LWP GET that bypasses
#    MediaWiki::API; wrapped in our own mw_retry() exponential-backoff loop.
#
# Configurable with remote.<remotename>.maxRetries (retries *after* the first
# attempt); 0 disables retrying. Default 3.
my $max_retries = run_git_quoted(["config", "--get", "--int", "remote.${remotename}.maxRetries"]);
chomp($max_retries);
if ($max_retries eq q{}) {
	$max_retries = 3;
}
if ($max_retries < 0) {
	$max_retries = 0;
}

# Fetch (clone and pull) by revisions instead of by pages. This behavior
# is more efficient when we have a wiki with lots of pages and we fetch
# the revisions quite often so that they concern only few pages.
# Possible values:
# - by_rev: perform one query per new revision on the remote wiki
# - by_page: query each tracked page for new revision
my $fetch_strategy = run_git_quoted(["config", "--get", "remote.${remotename}.fetchStrategy"]);
if (!$fetch_strategy) {
	$fetch_strategy = run_git_quoted(["config", "--get", "mediawiki.fetchStrategy"]);
}
chomp($fetch_strategy);

# Force by_page if we are given a set of pages.
#
# This is especially needed on initial clones from large wikis since, if fetchStrategy is set to
# by_rev, an array containing all revisions ids is created in mw_import_ref_by_revs.  On large wikis
# (e.g. Wikipedia) this results in an OOM error.
# See https://github.com/Git-Mediawiki/Git-Mediawiki/issues/71
if (!$fetch_strategy || $#tracked_pages > -1 ) {
	$fetch_strategy = 'by_page';
}

# Remember the timestamp corresponding to a revision id.
my %basetimestamps;

# Dumb push: don't update notes and mediawiki ref to reflect the last push.
#
# Configurable with mediawiki.dumbPush, or per-remote with
# remote.<remotename>.dumbPush.
#
# This means the user will have to re-import the just-pushed
# revisions. On the other hand, this means that the Git revisions
# corresponding to MediaWiki revisions are all imported from the wiki,
# regardless of whether they were initially created in Git or from the
# web interface, hence all users will get the same history (i.e. if
# the push from Git to MediaWiki loses some information, everybody
# will get the history with information lost). If the import is
# deterministic, this means everybody gets the same sha1 for each
# MediaWiki revision.
my $dumb_push = run_git_quoted(["config", "--get", "--bool", "remote.${remotename}.dumbPush"]);
if (!$dumb_push) {
	$dumb_push = run_git_quoted(["config", "--get", "--bool", "mediawiki.dumbPush"]);
}
chomp($dumb_push);
$dumb_push = ($dumb_push eq 'true');

# Resumable push: checkpoint the last fully-pushed commit on a per-remote ref so
# an INTERRUPTED push (crash, deadlock, dropped connection, Ctrl-C) resumes from
# there on the next push instead of re-sending every page. Enabled by default;
# set remote.<remotename>.pushResume=false (or mediawiki.pushResume=false) to
# disable. The checkpoint is deleted on a fully successful push. (Local fork
# change -- resumability for bulk content sync.)
my $push_resume = run_git_quoted(["config", "--get", "--bool", "remote.${remotename}.pushResume"]);
chomp($push_resume);
if ($push_resume eq q{}) {
	$push_resume = run_git_quoted(["config", "--get", "--bool", "mediawiki.pushResume"]);
	chomp($push_resume);
}
$push_resume = ($push_resume ne 'false');   # default ON: empty or 'true' enables

# Truly delete removed pages on push instead of overwriting them with a deletion
# marker. The marker convention (deleted_content_for_title) exists because
# deleting a page needs privileges most users lack; an UNPRIVILEGED push must
# keep using it. But a privileged restore (e.g. a sysop bot rebuilding a wiki
# from a clone) wants a removed page to be GONE (HTTP 404), not left as a visible
# empty marker page -- which still renders as a real page and diverges from the
# source wiki. When enabled, the
# $page_deleted branch in mw_push_file issues action=delete, matching what
# mw_upload_file already does for files. Default OFF (privilege-safe); set
# remote.<remotename>.deletePages=true (or mediawiki.deletePages=true) to enable.
# The import side is unchanged: a deleted page already round-trips as an absent
# git file ('D'), so deleted -> absent -> action=delete is symmetric. (Local fork
# change -- faithful privileged restore.)
my $delete_pages = run_git_quoted(["config", "--get", "--bool", "remote.${remotename}.deletePages"]);
chomp($delete_pages);
if ($delete_pages eq q{}) {
	$delete_pages = run_git_quoted(["config", "--get", "--bool", "mediawiki.deletePages"]);
	chomp($delete_pages);
}
$delete_pages = ($delete_pages eq 'true');   # default OFF: only explicit 'true' enables

my $wiki_name = $url;
$wiki_name =~ s{[^/]*://}{};
# If URL is like http://user:password@example.com/, we clearly don't
# want the password in $wiki_name. While we're there, also remove user
# and '@' sign, to avoid author like MWUser@HTTPUser@host.com
$wiki_name =~ s/^.*@//;

# Commands parser
while (<STDIN>) {
	chomp;

	if (!parse_command($_)) {
		last;
	}

	BEGIN { $| = 1 } # flush STDOUT, to make sure the previous
			 # command is fully processed.
}

########################## Functions ##############################

## error handling
sub exit_error_usage {
	die "ERROR: git-remote-mediawiki module was not called with a correct number of\n" .
		"parameters\n" .
		"You may obtain this error because you attempted to run the git-remote-mediawiki\n" .
		"module directly.\n" .
		"This module can be used the following way:\n" .
		"\tgit clone mediawiki://<address of a mediawiki>\n" .
		"Then, use git commit, push and pull as with every normal git repository.\n";
}

sub parse_command {
	my ($line) = @_;
	my @cmd = split(/ /, $line);
	if (!defined $cmd[0]) {
		return 0;
	}
	if ($cmd[0] eq 'capabilities') {
		die("Too many arguments for capabilities\n")
			if (defined($cmd[1]));
		mw_capabilities();
	} elsif ($cmd[0] eq 'list') {
		die("Too many arguments for list\n") if (defined($cmd[2]));
		mw_list($cmd[1]);
	} elsif ($cmd[0] eq 'import') {
		die("Invalid argument for import\n")
			if ($cmd[1] eq EMPTY);
		die("Too many arguments for import\n")
			if (defined($cmd[2]));
		mw_import($cmd[1]);
	} elsif ($cmd[0] eq 'option') {
		die("Invalid arguments for option\n")
			if ($cmd[1] eq EMPTY || $cmd[2] eq EMPTY);
		die("Too many arguments for option\n")
			if (defined($cmd[3]));
		mw_option($cmd[1],$cmd[2]);
	} elsif ($cmd[0] eq 'push') {
		mw_push($cmd[1]);
	} else {
		print {*STDERR} "Unknown command. Aborting...\n";
		return 0;
	}
	return 1;
}

# MediaWiki API instance, created lazily.
my $mediawiki;

sub fatal_mw_error {
	my $action = shift;
	print STDERR "fatal: could not $action.\n";
	print STDERR "fatal: '$url' does not appear to be a mediawiki\n";
	if ($url =~ /^https/) {
		print STDERR "fatal: make sure '$url/api.php' is a valid page\n";
		print STDERR "fatal: and the SSL certificate is correct.\n";
	} else {
		print STDERR "fatal: make sure '$url/api.php' is a valid page.\n";
	}
	print STDERR "fatal: (error " . $mediawiki->{error}->{code} . ': ' .
		$mediawiki->{error}->{details} . ")\n";
	exit 1;
}

# Is this HTTP status code a transient (retryable) failure?
# Retry on timeout (408), rate-limit (429) and any 5xx server error. Permanent
# client errors (400/401/403/404, ...) and a 200 carrying a semantic API error
# are NOT retried. Note LWP reports connection timeout / reset / DNS failure as
# an internal 500 (e.g. "Can't connect ...", "read timeout"), so those network
# blips fall under the 5xx case and are retried too; a bare 0 (no response
# object) is treated as transient defensively.
sub is_transient_http_code {
	my $code = shift;
	return 1 if !defined($code) || $code == 0;
	return 1 if $code == HTTP_CODE_REQUEST_TIMEOUT;
	return 1 if $code == HTTP_CODE_TOO_MANY_REQUESTS;
	# 5xx server errors, and LWP's internal 5xx codes used when no HTTP response
	# arrived (connection refused / reset / timeout / DNS failure).
	return 1 if $code >= 500 && $code <= 599;
	return 0;
}

# Run a network operation with exponential-backoff retry on transient failure.
#
#   mw_retry($what, $is_transient, $attempt) where:
#     $what         - short human description for messages (e.g. "download foo")
#     $is_transient - coderef: given the result of $attempt, return true if the
#                     failure is transient and should be retried, false/empty if
#                     it succeeded or failed permanently.
#     $attempt      - coderef performing one try; its return value is passed to
#                     $is_transient and, on success, returned by mw_retry.
#
# Retries up to $max_retries times with backoff 1s, 2s, 4s ... capped at
# RETRY_BACKOFF_MAX. After exhausting retries on a still-transient failure it
# returns the last result (the caller then fails loud); it never silently skips.
sub mw_retry {
	my ($what, $is_transient, $attempt) = @_;
	my $result;
	my $backoff = RETRY_BACKOFF_BASE;
	for (my $try = 0; ; $try++) {
		$result = $attempt->();
		# Success or permanent failure: hand back to the caller immediately.
		if (!$is_transient->($result)) {
			return $result;
		}
		# Transient failure: stop once we have used up our retry budget.
		if ($try >= $max_retries) {
			print {*STDERR} "Retried to $what $max_retries time(s); giving up.\n";
			return $result;
		}
		print {*STDERR} "Transient failure to $what; retrying in ${backoff}s " .
			'(attempt ' . ($try + 2) . ' of ' . ($max_retries + 1) . ").\n";
		sleep $backoff;
		$backoff *= 2;
		if ($backoff > RETRY_BACKOFF_MAX) {
			$backoff = RETRY_BACKOFF_MAX;
		}
	}
}

## Functions for listing pages on the remote wiki
sub get_mw_tracked_pages {
	my $pages = shift;
	get_mw_page_list(\@tracked_pages, $pages);
	return;
}

sub get_mw_page_list {
	my $page_list = shift;
	my $pages = shift;
	my @some_pages = @{$page_list};
	while (@some_pages) {
		# Batch by SLICE_SIZE TITLES per query. The API caps the `titles`
		# parameter at 50 for non-bot logins, so each slice must hold exactly
		# SLICE_SIZE elements -- indices 0..SLICE_SIZE-1. The old 0..SLICE_SIZE
		# took SLICE_SIZE+1 (51) and the API rejected the whole query
		# ("too many values supplied for parameter titles. The limit is 50"),
		# so tracking more than 50 individual pages failed outright. The leftover
		# tail must then start at SLICE_SIZE, not SLICE_SIZE+1. (Local fork change.)
		my $last_page = SLICE_SIZE - 1;
		if ($#some_pages < $last_page) {
			$last_page = $#some_pages;
		}
		my @slice = @some_pages[0..$last_page];
		get_mw_first_pages(\@slice, $pages);
		@some_pages = @some_pages[SLICE_SIZE..$#some_pages];
	}
	return;
}

sub get_mw_tracked_categories {
	my $pages = shift;
	foreach my $category (@tracked_categories) {
		if (index($category, ':') < 0) {
			# Mediawiki requires the Category
			# prefix, but let's not force the user
			# to specify it.
			$category = "Category:${category}";
		}
		my $mw_pages = $mediawiki->list( {
			action => 'query',
			list => 'categorymembers',
			cmtitle => $category,
			cmlimit => 'max' } )
			|| die $mediawiki->{error}->{code} . ': '
				. $mediawiki->{error}->{details} . "\n";
		foreach my $page (@{$mw_pages}) {
			$pages->{$page->{title}} = $page;
		}
	}
	return;
}

sub get_mw_tracked_namespaces {
	my $pages = shift;
	foreach my $local_namespace (sort @tracked_namespaces) {
		my $namespace_id;
		if ($local_namespace eq "(Main)") {
			$namespace_id = 0;
		} else {
			$namespace_id = get_mw_namespace_id($local_namespace);
		}
		# virtual namespaces don't support allpages
		next if !defined($namespace_id) || $namespace_id < 0;
		my $mw_pages = $mediawiki->list( {
			action => 'query',
			list => 'allpages',
			apnamespace => $namespace_id,
			aplimit => 'max' } );
		if (!defined($mw_pages)) {
			# A tracked namespace may not exist on the remote wiki. When its
			# id is not a valid namespace there, the API rejects
			# apnamespace=<id> with a 'badvalue' ("Unrecognized value for
			# parameter apnamespace") error. Treat that as an empty
			# namespace -- warn and skip it -- rather than aborting the
			# whole fetch/push.
			my $code    = $mediawiki->{error}->{code}    // q{};
			my $details = $mediawiki->{error}->{details} // q{};
			if ($details =~ /apnamespace/ && $details =~ /badvalue|Unrecognized[ ]value/i) {
				print {*STDERR} "warning: skipping tracked namespace $local_namespace ($namespace_id): not present on this wiki ($details)\n";
				next;
			}
			die "$code: $details\n";
		}
		print {*STDERR} "$#{$mw_pages} found in namespace $local_namespace ($namespace_id)\n";
		foreach my $page (@{$mw_pages}) {
			$pages->{$page->{title}} = $page;
		}
	}
	return;
}

sub get_mw_all_pages {
	my $pages = shift;
	# No user-provided list, get the list of pages from the API.
	my $mw_pages = $mediawiki->list({
		action => 'query',
		list => 'allpages',
		aplimit => 'max'
	});
	if (!defined($mw_pages)) {
		fatal_mw_error("get the list of wiki pages");
	}
	foreach my $page (@{$mw_pages}) {
		$pages->{$page->{title}} = $page;
	}
	return;
}

# queries the wiki for a set of pages. Meant to be used within a loop
# querying the wiki for slices of page list.
sub get_mw_first_pages {
	my $some_pages = shift;
	my @some_pages = @{$some_pages};

	my $pages = shift;

	# pattern 'page1|page2|...' required by the API
	my $titles = join('|', @some_pages);

	my $mw_pages = $mediawiki->api({
		action => 'query',
		titles => $titles,
	});
	if (!defined($mw_pages)) {
		fatal_mw_error("query the list of wiki pages");
	}
	while (my ($id, $page) = each(%{$mw_pages->{query}->{pages}})) {
		if ($id < 0) {
			# A File: page (ns 6) can exist as an uploaded binary with NO
			# wikitext description page. The API then reports it "missing"
			# (negative id), but the file is real and is synced via the
			# mediaimport / backfill paths regardless of the description.
			# Emitting "not found on wiki" for these is wrong and was pure
			# spam on wikis with description-less files, so skip the warning
			# for the File namespace (genuinely missing non-File pages still
			# warn).
			next if defined($page->{ns}) && $page->{ns} == 6;
			print {*STDERR} "Warning: page $page->{title} not found on wiki\n";
		} else {
			$pages->{$page->{title}} = $page;
		}
	}
	return;
}

# Get the list of pages to be fetched according to configuration.
sub get_mw_pages {
	$mediawiki = connect_maybe($mediawiki, $remotename, $url);

	print {*STDERR} "Listing pages on remote wiki...\n";

	my %pages; # hash on page titles to avoid duplicates
	my $user_defined;
	if (@tracked_pages) {
		$user_defined = 1;
		# The user provided a list of pages titles, but we
		# still need to query the API to get the page IDs.
		get_mw_tracked_pages(\%pages);
	}
	if (@tracked_categories) {
		$user_defined = 1;
		get_mw_tracked_categories(\%pages);
	}
	if (@tracked_namespaces) {
		$user_defined = 1;
		get_mw_tracked_namespaces(\%pages);
	}
	if (!$user_defined) {
		get_mw_all_pages(\%pages);
	}
	if ($import_media) {
		print {*STDERR} "Getting media files for selected pages...\n";
		if ($user_defined) {
			get_linked_mediafiles(\%pages);
		} else {
			get_all_mediafiles(\%pages);
		}
	}
	print {*STDERR} (scalar keys %pages) . " pages found.\n";
	return %pages;
}

# usage: $out = run_git_quoted(["command", "args", ...]);
#        $out = run_git_quoted(["command", "args", ...], "raw"); # don't interpret output as UTF-8.
#        $out = run_git_quoted_nostderr(["command", "args", ...]); # discard stderr
#        $out = run_git_quoted_nostderr(["command", "args", ...], "raw"); # ditto but raw instead of UTF-8 as above
sub _run_git {
	my $args = shift;
	my $encoding = (shift || 'encoding(UTF-8)');
	open(my $git, "-|:${encoding}", @$args)
	    or die "Unable to fork: $!\n";
	my $res = do {
		local $/ = undef;
		<$git>
	};
	close($git);

	return $res;
}

sub run_git_quoted {
    _run_git(["git", @{$_[0]}], $_[1]);
}

sub run_git_quoted_nostderr {
    _run_git(['sh', '-c', 'git "$@" 2>/dev/null', '--', @{$_[0]}], $_[1]);
}

sub get_all_mediafiles {
	my $pages = shift;
	# Attach list of all pages for media files from the API,
	# they are in a different namespace, only one namespace
	# can be queried at the same moment
	my $mw_pages = $mediawiki->list({
		action => 'query',
		list => 'allpages',
		apnamespace => get_mw_namespace_id('File'),
		aplimit => 'max'
	});
	if (!defined($mw_pages)) {
		print {*STDERR} "fatal: could not get the list of pages for media files.\n";
		print {*STDERR} "fatal: '$url' does not appear to be a mediawiki\n";
		print {*STDERR} "fatal: make sure '$url/api.php' is a valid page.\n";
		exit 1;
	}
	foreach my $page (@{$mw_pages}) {
		$pages->{$page->{title}} = $page;
	}
	return;
}

sub get_linked_mediafiles {
	my $pages = shift;
	my @titles = map { $_->{title} } values(%{$pages});

	my $batch = BATCH_SIZE;
	while (@titles) {
		if ($#titles < $batch) {
			$batch = $#titles;
		}
		my @slice = @titles[0..$batch];

		# pattern 'page1|page2|...' required by the API
		my $mw_titles = join('|', @slice);

		# Media files could be included or linked from a page; get all related.
		# A page's links/images lists can exceed one API response, so follow the
		# continuation cursor: a single api() call (unlike ->list()) does NOT
		# auto-continue, and imlimit was never set -- so without this, linked
		# media on heavily-linked pages was silently dropped. Handle the modern
		# 'continue' and legacy 'query-continue' forms. (Local fork change.)
		my $query = {
			action => 'query',
			prop => 'links|images',
			titles => $mw_titles,
			plnamespace => get_mw_namespace_id('File'),
			pllimit => 'max',
			imlimit => 'max',
		};
		my $rounds = 0;
		while (1) {
			my $result = $mediawiki->api($query);

			while (my ($id, $page) = each(%{$result->{query}->{pages}})) {
				my @media_titles;
				if (defined($page->{links})) {
					push(@media_titles, map { $_->{title} } @{$page->{links}});
				}
				if (defined($page->{images})) {
					push(@media_titles, map { $_->{title} } @{$page->{images}});
				}
				if (@media_titles) {
					get_mw_page_list(\@media_titles, $pages);
				}
			}

			if ($result->{continue}) {
				$query = { %{$query}, %{$result->{continue}} };
			} elsif ($result->{'query-continue'}) {
				my $qc = $result->{'query-continue'};
				foreach my $mod (keys %{$qc}) {
					$query = { %{$query}, %{$qc->{$mod}} };
				}
			} else {
				last;
			}
			# Backstop a server returning a non-advancing continuation cursor
			# (which would otherwise loop forever): a real page exhausts in a
			# handful of rounds even at bot link limits. (Local fork change.)
			if (++$rounds >= 1000) {
				print {*STDERR} "Warning: get_linked_mediafiles continuation did not terminate after ${rounds} rounds; stopping to avoid a stuck cursor.\n";
				last;
			}
		}

		@titles = @titles[($batch+1)..$#titles];
	}
	return;
}

sub get_mw_mediafile_for_page_revision {
	# Name of the file on Wiki, with the prefix.
	my $filename = shift;
	my $timestamp = shift;
	my %mediafile;

	# Fetch the file version CURRENT AS OF this page revision -- NOT one uploaded
	# at the EXACT page-revision timestamp. A File: page's description revisions and
	# its file-upload versions are independent timelines: when the page was edited
	# or (re-)imported after the upload (e.g. a wiki migration's "1 revision
	# imported" commit), the latest page-revision timestamp matches NO file version.
	# The old iistart==iiend exact match then returned nothing and the binary was
	# silently skipped -- this is exactly why description-less / post-upload-edited
	# files (e.g. the payment-logo icons) cloned with an empty File: page and no
	# media. iistart alone enumerates newest-first from $timestamp backwards, so
	# iilimit=1 yields the version in effect at that revision. iidir=older is the
	# API default but is set EXPLICITLY so the direction never depends on a default
	# changing: it guarantees the single returned version is at-or-BEFORE $timestamp
	# (never a newer upload), and when the file's earliest version is itself newer
	# than this revision the result is simply empty -- the media backfill
	# (get_mw_current_mediafile, no timestamp) then fetches the current version.
	# (Local fork change.)
	my $query = {
		action => 'query',
		prop => 'imageinfo',
		titles => "File:${filename}",
		iistart => $timestamp,
		iidir => 'older',
		iiprop => 'timestamp|archivename|url',
		iilimit => 1
	};
	my $result = $mediawiki->api($query);

	my ($fileid, $file) = each( %{$result->{query}->{pages}} );
	# If not defined it means there is no revision of the file for
	# given timestamp.
	if (defined($file->{imageinfo})) {
		my $fileinfo = pop(@{$file->{imageinfo}});
		# Mediawiki::API's download function doesn't support https URLs
		# and can't download old versions of files.
		print {*STDERR} "\tDownloading file $filename, version $fileinfo->{timestamp}\n";
		my $content = download_mw_mediafile($fileinfo->{url});
		if (defined($content)) {
			$mediafile{content} = $content;
			$mediafile{title} = $filename;
			$mediafile{timestamp} = $fileinfo->{timestamp};
		} else {
			print {*STDERR} "\tFAILED downloading $fileinfo->{url}! Skipping!\n";
		}
	}
	return %mediafile;
}

# Fetch the CURRENT (latest) version of a File: page's media, regardless of
# any per-revision timestamp. Used by the media backfill, which heals a clone
# whose binary is missing rather than tracking a specific historical revision.
sub get_mw_current_mediafile {
	# Name of the file on Wiki, without the File: prefix.
	my $filename = shift;
	my %mediafile;

	my $query = {
		action => 'query',
		prop => 'imageinfo',
		titles => "File:${filename}",
		iiprop => 'timestamp|url',
		iilimit => 1
	};
	my $result = $mediawiki->api($query);

	my ($fileid, $file) = each( %{$result->{query}->{pages}} );
	if (defined($file->{imageinfo})) {
		my $fileinfo = pop(@{$file->{imageinfo}});
		print {*STDERR} "\tBackfilling file $filename, version $fileinfo->{timestamp}\n";
		my $content = download_mw_mediafile($fileinfo->{url});
		if (defined($content)) {
			$mediafile{content} = $content;
			$mediafile{title} = $filename;
			$mediafile{timestamp} = $fileinfo->{timestamp};
		} else {
			print {*STDERR} "\tFAILED downloading $fileinfo->{url}! Skipping!\n";
		}
	}
	return %mediafile;
}

sub download_mw_mediafile {
	my $download_url = shift;

	# The media URL can legitimately carry credentials in its userinfo (see the
	# "user:password@" fallback below), so NEVER log it raw -- redact the
	# userinfo for any progress / error / fatal message. (Local fork change.)
	my $display_url = $download_url;
	$display_url =~ s{^([^:/?#]+://)[^/@]*@}{${1}<redacted>@};

	# This GET goes straight through LWP and bypasses MediaWiki::API's retry
	# loop, so harden it ourselves: retry transient failures (timeout, reset,
	# 408/429/5xx) with exponential backoff. Permanent failures (404/403/...)
	# fall through without retrying.
	my $response = mw_retry(
		"download mediafile $display_url",
		sub { my $r = shift; return is_transient_http_code($r->code); },
		sub { return $mediawiki->{ua}->get($download_url); },
	);
	if ($response->code == HTTP_CODE_OK) {
		# It is tempting to return
		# $response->decoded_content({charset => "none"}), but
		# when doing so, utf8::downgrade($content) fails with
		# "Wide character in subroutine entry".
		$response->decode();
		return $response->content();
	} elsif (($download_url !~ /^\Q$url\E/) and ($download_url =~ m{\Q$wiki_name\E/})) {
		# We may have failed because the URL returned from the API
		# is missing something (e.g. "user:password@"). Retry with a
		# corresponding URL constructed from our original $url.
		$download_url =~ s{.*?\Q$wiki_name\E/}{$url/};
		return download_mw_mediafile($download_url);
	} else {
		# Transient retries (if any) are already exhausted here. Fail loud:
		# a still-failing transient code (timeout/5xx) must abort the fetch
		# rather than silently dropping the media file. Permanent codes
		# (404/403/...) are reported the same way by the caller.
		print {*STDERR} "Error downloading mediafile from :\n";
		print {*STDERR} "URL: ${display_url}\n";
		print {*STDERR} 'Server response: ' . $response->code . q{ } . $response->message . "\n";
		if (is_transient_http_code($response->code)) {
			die "fatal: persistent transient error downloading $display_url " .
				'(HTTP ' . $response->code . q{ } . $response->message . ")\n";
		}
		return;
	}
}

sub get_last_local_revision {
	# Get note regarding last mediawiki revision.
	my $note = run_git_quoted_nostderr(["notes", "--ref=${remotename}/mediawiki",
					    "show", "refs/mediawiki/${remotename}/master"]);
	my @note_info = split(/ /, $note);

	my $lastrevision_number;
	if (!(defined($note_info[0]) && $note_info[0] eq 'mediawiki_revision:')) {
		print {*STDERR} 'No previous mediawiki revision found';
		$lastrevision_number = 0;
	} else {
		# Notes are formatted : mediawiki_revision: #number
		$lastrevision_number = $note_info[1];
		chomp($lastrevision_number);
		print {*STDERR} "Last local mediawiki revision found is ${lastrevision_number}";
	}
	return $lastrevision_number;
}

# Get the last remote revision without taking in account which pages are
# tracked or not. This function makes a single request to the wiki thus
# avoid a loop onto all tracked pages. This is useful for the fetch-by-rev
# option.
sub get_last_global_remote_rev {
	$mediawiki = connect_maybe($mediawiki, $remotename, $url);

	my $query = {
		action => 'query',
		list => 'recentchanges',
		prop => 'revisions',
		rclimit => '1',
		rcdir => 'older',
	};
	my $result = $mediawiki->api($query);
	return $result->{query}->{recentchanges}[0]->{revid};
}

# Get the last remote revision concerning the tracked pages and the tracked
# categories.
sub get_last_remote_revision {
	$mediawiki = connect_maybe($mediawiki, $remotename, $url);

	# Full-wiki mirror (no tracked page/category/namespace subset): the last
	# revision "concerning the tracked pages" is just the wiki's global last
	# revision, so one recentchanges query answers it -- instead of one API
	# round-trip PER page (thousands of serial calls before any push work begins
	# on a large wiki). The three conditions mirror get_mw_pages's $user_defined
	# exactly; only the per-page scan below can answer a tracked SUBSET (incl. a
	# namespace-restricted clone) correctly, so keep it for that. (Local fork change.)
	if (!@tracked_pages && !@tracked_categories && !@tracked_namespaces) {
		return get_last_global_remote_rev();
	}

	my %pages_hash = get_mw_pages();
	my @pages = values(%pages_hash);

	my $max_rev_num = 0;

	print {*STDERR} "Getting last revision id on tracked pages...\n";

	foreach my $page (@pages) {
		my $id = $page->{pageid};

		my $query = {
			action => 'query',
			prop => 'revisions',
			rvprop => 'ids|timestamp',
			pageids => $id,
		};

		my $result = $mediawiki->api($query);

		my $lastrev = pop(@{$result->{query}->{pages}->{$id}->{revisions}});

		$basetimestamps{$lastrev->{revid}} = $lastrev->{timestamp};

		$max_rev_num = ($lastrev->{revid} > $max_rev_num ? $lastrev->{revid} : $max_rev_num);
	}

	print {*STDERR} "Last remote revision found is $max_rev_num.\n";
	return $max_rev_num;
}

# Clean content before sending it to MediaWiki
sub mediawiki_clean {
	my $string = shift;
	my $page_created = shift;
	# Mediawiki does not allow blank space at the end of a page and ends with a single \n.
	# This function right trims a string and adds a \n at the end to follow this rule
	$string =~ s/\s+$//;
	# The old code substituted EMPTY_CONTENT ("<!-- empty page -->") here when
	# creating a NEW empty page, on the assumption that "creating empty pages is
	# forbidden". That is not true for the action=edit API on modern MediaWiki
	# (verified: it creates a genuinely empty page), and the visible placeholder
	# LEAKS for any page whose content is consumed as a plain string -- e.g. the
	# MediaWiki:Aboutsite interface message rendered "<!-- empty page -->" as the
	# footer's About-link text. Push the empty content unchanged so the wiki page
	# matches the (empty) source. mediawiki_smudge below still maps any legacy
	# EMPTY_CONTENT a previously-pushed wiki carries back to empty on import, so
	# the round-trip stays consistent for wikis written by the old behaviour.
	# ($page_created is retained in the signature but no longer consulted.)
	return $string."\n";
}

# Filter applied on MediaWiki data before adding them to Git
sub mediawiki_smudge {
	my $string = shift;
	if ($string eq EMPTY_CONTENT) {
		$string = EMPTY;
	}
	# This \n is important. This is due to mediawiki's way to handle end of files.
	return "${string}\n";
}

sub literal_data {
	my ($content) = @_;
	print {*STDOUT} 'data ', bytes::length($content), "\n", $content;
	return;
}

sub literal_data_raw {
	# Output possibly binary content.
	my ($content) = @_;
	# Avoid confusion between size in bytes and in characters
	utf8::downgrade($content);
	binmode STDOUT, ':raw';
	print {*STDOUT} 'data ', bytes::length($content), "\n", $content;
	binmode STDOUT, ':encoding(UTF-8)';
	return;
}

sub mw_capabilities {
	# Revisions are imported to the private namespace
	# refs/mediawiki/$remotename/ by the helper and fetched into
	# refs/remotes/$remotename later by fetch.
	print {*STDOUT} "refspec refs/heads/*:refs/mediawiki/${remotename}/*\n";
	print {*STDOUT} "import\n";
	print {*STDOUT} "list\n";
	print {*STDOUT} "push\n";
	if ($dumb_push) {
		print {*STDOUT} "no-private-update\n";
	}
	print {*STDOUT} "\n";
	return;
}

sub mw_list {
	# MediaWiki do not have branches, we consider one branch arbitrarily
	# called master, and HEAD pointing to it.
	print {*STDOUT} "? refs/heads/master\n";
	print {*STDOUT} "\@refs/heads/master HEAD\n";
	print {*STDOUT} "\n";
	return;
}

sub mw_option {
	print {*STDERR} "remote-helper command 'option $_[0]' not yet implemented\n";
	print {*STDOUT} "unsupported\n";
	return;
}

sub fetch_mw_revisions_for_page {
	my $page = shift;
	my $id = shift;
	my $fetch_from = shift;
	my @page_revs = ();
	my $query = {
		action => 'query',
		prop => 'revisions',
		rvprop => 'ids',
		rvdir => 'newer',
		rvlimit => 500,
		pageids => $id,

		# Let MediaWiki know that we support the latest API.
		continue => '',
	};

	# Don't add the start if it is 1 since not all pages start at 1
	if ($fetch_from != 1) {
		$query->{rvstartid} = $fetch_from;
	}

	my $revnum = 0;
	# Get 500 revisions at a time due to the mediawiki api limit
	while (1) {
		my $result = $mediawiki->api($query);

		# Parse each of those 500 revisions
		foreach my $revision (@{$result->{query}->{pages}->{$id}->{revisions}}) {
			my $page_rev_ids;
			$page_rev_ids->{pageid} = $page->{pageid};
			$page_rev_ids->{revid} = $revision->{revid};
			push(@page_revs, $page_rev_ids);
			$revnum++;
		}

		if ($result->{'query-continue'}) { # For legacy APIs
			$query->{rvstartid} = $result->{'query-continue'}->{revisions}->{rvstartid};
		} elsif ($result->{continue}) { # For newer APIs
			$query->{rvcontinue} = $result->{continue}->{rvcontinue};
			$query->{continue} = $result->{continue}->{continue};
		} else {
			last;
		}
	}
	if ($shallow_import && @page_revs) {
		print {*STDERR} "  Found 1 revision (shallow import).\n";
		@page_revs = sort {$b->{revid} <=> $a->{revid}} (@page_revs);
		return $page_revs[0];
	}
	print {*STDERR} "  Found ${revnum} revision(s).\n";
	return @page_revs;
}

sub fetch_mw_revisions {
	my $pages = shift; my @pages = @{$pages};
	my $fetch_from = shift;

	my @revisions = ();
	my $n = 1;
	foreach my $page (@pages) {
		my $id = $page->{pageid};
		print {*STDERR} "page ${n}/", scalar(@pages), ': ', $page->{title}, "\n";
		$n++;
		my @page_revs = fetch_mw_revisions_for_page($page, $id, $fetch_from);
		# push() rather than prepend (@page_revs, @revisions): the prepend
		# rebuilt and recopied the whole growing list per page -- O(pages^2),
		# ~10^8 copies on a 10k-page clone. The caller sorts @revisions by revid
		# afterwards, so accumulation order does not matter. (Local fork change.)
		push(@revisions, @page_revs);
	}

	return ($n, @revisions);
}

sub fe_escape_path {
	my $path = shift;
	$path =~ s/\\/\\\\/g;
	$path =~ s/"/\\"/g;
	$path =~ s/\n/\\n/g;
	return qq("${path}");
}

# Push: the deletion marker to write for a removed page, valid for its content
# model (inferred from the title suffix). Import: whether some content IS one of
# those markers (a deletion). The two MUST agree. (Local fork change.)
sub deleted_content_for_title {
	my $title = shift;
	return DELETED_CONTENT_CSS if $title =~ /[.]css\z/;
	return DELETED_CONTENT_JS  if $title =~ /[.]js\z/;
	return DELETED_CONTENT;
}

sub is_deleted_marker {
	my $content = shift;
	return $content eq DELETED_CONTENT
		|| $content eq DELETED_CONTENT_CSS
		|| $content eq DELETED_CONTENT_JS;
}

sub import_file_revision {
	my $commit = shift;
	my %commit = %{$commit};
	my $full_import = shift;
	my $n = shift;
	my $mediafile = shift;
	my %mediafile;
	if ($mediafile) {
		%mediafile = %{$mediafile};
	}

	my $title = $commit{title};
	my $comment = $commit{comment};
	my $content = $commit{content};
	my $author = $commit{author};
	my $date = $commit{date};

	# SECURITY (defence in depth): the wiki username is interpolated into the
	# fast-import "committer" lines below. MediaWiki forbids these characters in
	# usernames, but never trust the remote to enforce it -- a CR/LF would break
	# the stream, '<'/'>' would corrupt the committer ident.
	$author =~ s/[\r\n<>]/ /g;

	print {*STDOUT} "commit refs/mediawiki/${remotename}/master\n";
	print {*STDOUT} "mark :${n}\n";
	print {*STDOUT} "committer ${author} <${author}\@${wiki_name}> " . $date->epoch . " +0000\n";
	literal_data($comment);

	# If it's not a clone, we need to know where to start from
	if (!$full_import && $n == 1) {
		print {*STDOUT} "from refs/mediawiki/${remotename}/master^0\n";
	}
	if (!is_deleted_marker($content)) {
		print {*STDOUT} 'M 644 inline ' .
			fe_escape_path("${title}.mw") . "\n";
		literal_data($content);
		if (%mediafile) {
			my $media_path = media_tree_path($mediafile{title});
			print {*STDOUT} 'M 644 inline '
				. fe_escape_path($media_path) . "\n";
			literal_data_raw($mediafile{content});
		}
		print {*STDOUT} "\n\n";
	} else {
		print {*STDOUT} 'D ' . fe_escape_path("${title}.mw") . "\n";
	}

	# mediawiki revision number in the git note
	if ($full_import && $n == 1) {
		print {*STDOUT} "reset refs/notes/${remotename}/mediawiki\n";
	}
	print {*STDOUT} "commit refs/notes/${remotename}/mediawiki\n";
	print {*STDOUT} "committer ${author} <${author}\@${wiki_name}> " . $date->epoch . " +0000\n";
	literal_data('Note added by git-mediawiki during import');
	if (!$full_import && $n == 1) {
		print {*STDOUT} "from refs/notes/${remotename}/mediawiki^0\n";
	}
	print {*STDOUT} "N inline :${n}\n";
	literal_data("mediawiki_revision: $commit{mw_revision}");
	print {*STDOUT} "\n\n";
	return;
}

# Map a wiki media filename (the part after "File:") to the path the binary is
# stored at in the imported tree.
#
# SECURITY: the media filename comes straight from the wiki and is NOT run
# through smudge_filename, so neutralise path separators and control bytes
# before using it as a fast-import path (no traversal / subdir injection).
# Mirrors the smudge_filename hardening. Both the import write path
# (import_file_revision) and the backfill presence check MUST use this single
# definition; if they diverged, the backfill would mis-detect presence and
# either re-fetch forever or never heal.
sub media_tree_path {
	my $title = shift;
	$title =~ s{[/\x00-\x1f]}{_}g;
	return $title;
}

# Backfill File: media whose binary is absent from the imported tree.
#
# Runs after the normal import (when remote.<remote>.backfillMedia is on). It
# enumerates every File: page on the wiki, checks whether the corresponding
# binary already exists in refs/mediawiki/<remote>/master, and for each missing
# one fetches + commits the *current* media version. This is what heals a clone
# originally taken with mediaimport=false: those File: pages have no new
# revision on an incremental fetch, so the per-revision media path never runs.
#
# $start_mark is the highest fast-import mark already used by this run; backfill
# commits use marks above it. Returns the number of binaries committed.
sub backfill_missing_mediafiles {
	my $start_mark = shift;

	$mediawiki = connect_maybe($mediawiki, $remotename, $url);

	# Only meaningful once the ref exists (i.e. something has been imported).
	my $tip = run_git_quoted_nostderr(
		["rev-parse", "--verify", "--quiet",
		 "refs/mediawiki/${remotename}/master"]);
	chomp($tip);
	if ($tip eq q{}) {
		print {*STDERR} "Media backfill: no imported ref yet, nothing to backfill.\n";
		return 0;
	}

	# Build the set of paths already present in the imported tree. The list is
	# read once; checking ~1k File: pages against an in-memory hash avoids a
	# git invocation per page.
	my %present;
	my $tree = run_git_quoted(
		["ls-tree", "-r", "-z", "--name-only",
		 "refs/mediawiki/${remotename}/master"], 'raw');
	for my $path (split(/\0/, $tree)) {
		$present{$path} = 1;
	}

	# Build the list of File: pages to consider, honouring the same tracked
	# pages/categories/namespaces scope as a normal import (get_mw_pages),
	# then keep only the File: namespace. This avoids pulling binaries for
	# File: pages outside the user's tracked scope.
	print {*STDERR} "Media backfill: listing File: pages on remote wiki...\n";
	my $file_ns = get_mw_namespace_id('File');
	my %pages = get_mw_pages();

	# Determine which File: binaries are missing locally.
	my @missing;
	my $total_files = 0;
	for my $title (keys %pages) {
		my ($namespace, $filename) = $title =~ /^([^:]*):(.*)$/;
		next if !defined($namespace) || !defined($filename) || $filename eq q{};
		my $id = get_mw_namespace_id($namespace);
		next if !defined($id) || $id != $file_ns;
		$total_files++;
		my $path = media_tree_path($filename);
		push(@missing, $filename) if !$present{$path};
	}

	my $missing_count = scalar @missing;
	print {*STDERR} "Media backfill: ${missing_count} of ${total_files} File: " .
		"binaries missing locally.\n";
	return 0 if $missing_count == 0;

	# Incremental-fetch bookkeeping uses the mediawiki_revision note on the
	# master TIP commit (get_last_local_revision reads
	# `git notes show refs/mediawiki/<remote>/master`). A backfill commit
	# advances that tip, so if it carried no note the next fetch would read an
	# empty note, treat the clone as having no imported revision, and re-import
	# the whole wiki from revision 1. Carry the current last-local revision
	# forward as a note on every backfill commit so the tip always has it.
	#
	# KNOWN LIMITATION: get_last_local_revision() reads the note off the on-disk
	# ref, which fast-import only flushes at a `checkpoint` or `done`. Backfill
	# runs in the same stream BEFORE `done`, so this can be up to
	# remote.<remote>.checkpointEvery revisions behind the latest just-imported
	# revision -- the carried note (and thus the next incremental fetch's start
	# point) may be that stale, causing the next fetch to RE-IMPORT those
	# revisions. That re-import is idempotent (no corruption, no data loss; a
	# re-edit to identical text is a MediaWiki no-op) and is moot for a one-shot
	# clone/restore, so it is left as-is; a full fix would thread the max revid
	# imported this run down from mw_import instead of re-reading the note.
	my $last_local_rev = get_last_local_revision();
	print {*STDERR} "\n";

	# Fetch + commit each missing binary. One fast-import commit per binary,
	# chained LINEARLY off the current import tip, each carrying the last
	# mediawiki_revision note forward (these are not new wiki revisions, only the
	# missing blob). The chain must be explicit: the first commit descends from
	# the existing master tip (bare ref, resolved via fast-import's in-stream
	# branch state or the on-disk ref), and every subsequent commit descends from
	# the previous backfill mark (`from :<prev>`). Using `^0` on every commit
	# re-resolves the ref to its unchanged on-disk value each time, which makes
	# the backfill commits SIBLINGS off one base rather than a chain, so only the
	# last commit per checkpoint batch survives in the ref and the rest dangle.
	# The note ref is chained the same way for the same reason.
	my $mark = $start_mark;
	my $prev_media_mark;
	my $prev_note_mark;
	my $committed = 0;
	my $n = 0;
	for my $filename (@missing) {
		$n++;
		print {*STDERR} "backfill ${n}/${missing_count}: File:${filename}\n";
		my %mediafile = get_mw_current_mediafile($filename);
		next if !%mediafile;

		$mark++;
		my $media_mark = $mark;
		my $media_path = media_tree_path($mediafile{title});
		my $epoch = 0;
		if (defined($mediafile{timestamp})) {
			$epoch = DateTime::Format::ISO8601
				->parse_datetime($mediafile{timestamp})->epoch;
		}
		print {*STDOUT} "commit refs/mediawiki/${remotename}/master\n";
		print {*STDOUT} "mark :${media_mark}\n";
		print {*STDOUT} "committer git-mediawiki <git-mediawiki\@${wiki_name}> " .
			"${epoch} +0000\n";
		literal_data("Backfill media for File:${filename}");
		# Chain the backfill commits, mirroring import_file_revision's `from`:
		#  - subsequent commits: `from :<prev mark>` (explicit chain).
		#  - first commit, import committed this run ($start_mark > 0): OMIT
		#    `from` so fast-import auto-chains to the import's in-stream tip. A
		#    bare `from refs/.../master` is rejected ("branch from itself").
		#  - first commit, nothing imported this run ($start_mark == 0): the
		#    branch is untracked in-stream, so chain to the on-disk tip via `^0`
		#    (exactly as import_file_revision does for its n==1 incremental case).
		# Using `^0` on EVERY commit (the original bug) re-reads the stale
		# on-disk value each time -> siblings, not a chain.
		if (defined($prev_media_mark)) {
			print {*STDOUT} "from :${prev_media_mark}\n";
		} elsif ($start_mark == 0) {
			print {*STDOUT} "from refs/mediawiki/${remotename}/master^0\n";
		}
		print {*STDOUT} 'M 644 inline ' . fe_escape_path($media_path) . "\n";
		literal_data_raw($mediafile{content});
		print {*STDOUT} "\n\n";
		$prev_media_mark = $media_mark;

		# Carry the mediawiki_revision note forward onto this new tip so
		# get_last_local_revision() keeps returning the right value (see above).
		# The note commits are chained too, otherwise the same sibling problem
		# would drop every note but the last per checkpoint batch.
		if ($last_local_rev > 0) {
			$mark++;
			my $note_mark = $mark;
			print {*STDOUT} "commit refs/notes/${remotename}/mediawiki\n";
			print {*STDOUT} "mark :${note_mark}\n";
			print {*STDOUT} "committer git-mediawiki <git-mediawiki\@${wiki_name}> " .
				"${epoch} +0000\n";
			literal_data('Note carried forward by git-mediawiki media backfill');
			# Same three-way chaining as the media commit above.
			if (defined($prev_note_mark)) {
				print {*STDOUT} "from :${prev_note_mark}\n";
			} elsif ($start_mark == 0) {
				print {*STDOUT} "from refs/notes/${remotename}/mediawiki^0\n";
			}
			print {*STDOUT} "N inline :${media_mark}\n";
			literal_data("mediawiki_revision: ${last_local_rev}");
			print {*STDOUT} "\n\n";
			$prev_note_mark = $note_mark;
		}
		$committed++;

		# Reuse the import checkpoint cadence so an interrupted backfill is
		# resumable: a re-run re-detects only the still-missing binaries.
		if ($checkpoint_every > 0 && $committed % $checkpoint_every == 0) {
			print {*STDERR} "Checkpointing fast-import after ${committed} backfilled media...\n";
			print {*STDOUT} "checkpoint\n";
		}
	}

	print {*STDERR} "Media backfill: committed ${committed} binary file(s).\n";
	return $committed;
}

# parse a sequence of
# <cmd> <arg1>
# <cmd> <arg2>
# \n
# (like batch sequence of import and sequence of push statements)
sub get_more_refs {
	my $cmd = shift;
	my @refs;
	while (1) {
		my $line = <STDIN>;
		if ($line =~ /^$cmd (.*)$/) {
			push(@refs, $1);
		} elsif ($line eq "\n") {
			return @refs;
		} else {
			die("Invalid command in a '$cmd' batch: $_\n");
		}
	}
	return;
}

sub mw_import {
	# multiple import commands can follow each other.
	my @refs = (shift, get_more_refs('import'));
	my $processedRefs;
	foreach my $ref (@refs) {
		next if $processedRefs->{$ref}; # skip duplicates: "import refs/heads/master" being issued twice; TODO: why?
		$processedRefs->{$ref} = 1;
		mw_import_ref($ref);
	}
	print {*STDOUT} "done\n";
	return;
}

sub mw_import_ref {
	my $ref = shift;
	# The remote helper will call "import HEAD" and
	# "import refs/heads/master".
	# Since HEAD is a symbolic ref to master (by convention,
	# followed by the output of the command "list" that we gave),
	# we don't need to do anything in this case.
	if ($ref eq 'HEAD') {
		return;
	}

	$mediawiki = connect_maybe($mediawiki, $remotename, $url);

	print {*STDERR} "Searching revisions...\n";
	my $last_local = get_last_local_revision();
	my $fetch_from = $last_local + 1;
	if ($fetch_from == 1) {
		print {*STDERR} ", fetching from beginning.\n";
	} else {
		print {*STDERR} ", fetching from here.\n";
	}

	my $n = 0;
	if ($fetch_strategy eq 'by_rev') {
		print {*STDERR} "Fetching & writing export data by revs...\n";
		$n = mw_import_ref_by_revs($fetch_from);
	} elsif ($fetch_strategy eq 'by_page') {
		print {*STDERR} "Fetching & writing export data by pages...\n";
		$n = mw_import_ref_by_pages($fetch_from);
	} else {
		print {*STDERR} qq(fatal: invalid fetch strategy "${fetch_strategy}".\n);
		print {*STDERR} "Check your configuration variables remote.${remotename}.fetchStrategy and mediawiki.fetchStrategy\n";
		exit 1;
	}

	# Heal File: pages whose binary is absent locally (e.g. clone first taken
	# with mediaimport=false). These have no new revision so the per-revision
	# media path above never fetches them. Backfill commits continue from the
	# tip and reuse fast-import marks above the last import mark ($n).
	if ($import_media && $backfill_media) {
		$n += backfill_missing_mediafiles($n);
	}

	if ($fetch_from == 1 && $n == 0) {
		print {*STDERR} "You appear to have cloned an empty MediaWiki.\n";
		# Something has to be done remote-helper side. If nothing is done, an error is
		# thrown saying that HEAD is referring to unknown object 0000000000000000000
		# and the clone fails.
	}
	return;
}

sub mw_import_ref_by_pages {

	my $fetch_from = shift;
	my %pages_hash = get_mw_pages();
	my @pages = values(%pages_hash);

	my ($n, @revisions) = fetch_mw_revisions(\@pages, $fetch_from);

	@revisions = sort {$a->{revid} <=> $b->{revid}} @revisions;
	my @revision_ids = map { $_->{revid} } @revisions;

	return mw_import_revids($fetch_from, \@revision_ids, \%pages_hash);
}

sub mw_import_ref_by_revs {

	my $fetch_from = shift;
	my %pages_hash = get_mw_pages();

	my $last_remote = get_last_global_remote_rev();
	my @revision_ids = $fetch_from..$last_remote;
	return mw_import_revids($fetch_from, \@revision_ids, \%pages_hash);
}

# Import revisions given in second argument (array of integers).
# Only pages appearing in the third argument (hash indexed by page titles)
# will be imported.
sub mw_import_revids {
	my $fetch_from = shift;
	my $revision_ids = shift;
	my $pages = shift;

	my $n = 0;
	my $n_actual = 0;
	my $maxRevs = 50;							# FIXME: Need to fetch max_revs per-repo in case they have a client
																# that can fetch more on a wiki

	while( scalar @$revision_ids > 0 ) {
		my @pageRevIds = splice @$revision_ids, 0, $maxRevs;
		# Count page even if we skip it, since we display
		# $n/$total and $total includes skipped pages.
		$n += scalar @pageRevIds;

		# fetch the content of the pages
		my $revs = join( "|", @pageRevIds );
		my $query = {
			action => 'query',
			prop => 'revisions',
			rvprop => 'content|timestamp|comment|user|ids',
			revids => $revs
		};

		my $result = $mediawiki->api($query);

		if (!$result) {
			die "Failed to retrieve modified page for revision(s) $revs\n";
		}

		my @result_pages = values(%{$result->{query}->{pages}});
		for my $result_page (@result_pages) {
			$n_actual = handle_result_page( $n, $n_actual, $fetch_from, $result_page, $pages, $revision_ids );
		}
	}

	return $n_actual;
}

sub handle_result_page {
	my ($n, $n_actual, $fetch_from, $result_page, $pages, $revision_ids) = @_;
	my $page_title = $result_page->{title};
	my $last_timestamp = 0;				# Placeholder in case $rev->timestamp is undefined

	for my $rev (@{$result_page->{revisions}}) {
		if (!exists($pages->{$page_title})) {
			print {*STDERR} "${n}/", scalar(@{$revision_ids}),
				": Skipping revision #$rev->{revid} of ${page_title}\n";
			next;
		}

		$n_actual++;

		my %commit;
		$commit{author} = $rev->{user} || 'Anonymous';
		$commit{comment} = $rev->{comment} || EMPTY_MESSAGE;
		$commit{title} = smudge_filename($page_title);
		$commit{mw_revision} = $rev->{revid};
		if ( defined $rev->{'*'} ) {
			$commit{content} = mediawiki_smudge($rev->{'*'});
		} else {
			# This may not be the best thing to do with suppressed revisions -- it creates a huge
			# difference between three revisions (e.g. 100000 chars -> ~30 chars -> 100000 chars).
			$commit{content} = SUPPRESSED_REVISION;
		}

		if (!defined($rev->{timestamp})) {
			$last_timestamp++;
		} else {
			$last_timestamp = $rev->{timestamp};
		}
		$commit{date} = DateTime::Format::ISO8601->parse_datetime($last_timestamp);

		# Differentiates classic pages and media files.
		my ($namespace, $filename) = $page_title =~ /^([^:]*):(.*)$/;
		my %mediafile;
		if ($namespace) {
			my $id = get_mw_namespace_id($namespace);
			if ($id && $id == get_mw_namespace_id('File')) {
				%mediafile = get_mw_mediafile_for_page_revision($filename, $rev->{timestamp});
			}
		}
		# If this is a revision of the media page for new version
		# of a file do one common commit for both file and media page.
		# Else do commit only for that page.
		print {*STDERR} "${n}/", scalar(@{$revision_ids}), ": Revision #$rev->{revid} of $commit{title}\n";
		import_file_revision(\%commit, ($fetch_from == 1), $n_actual, \%mediafile);

		# Periodically flush partial progress so an interrupted fetch can
		# resume after the last checkpointed revision (see $checkpoint_every).
		# Issued AFTER import_file_revision so the just-written commit + note
		# pair is part of what gets flushed.
		if ($checkpoint_every > 0 && $n_actual % $checkpoint_every == 0) {
			print {*STDERR} "Checkpointing fast-import after ${n_actual} revisions...\n";
			print {*STDOUT} "checkpoint\n";
		}
	}

	return $n_actual;
}

sub error_non_fast_forward {
	my $advice = run_git_quoted(["config", "--bool", "advice.pushNonFastForward"]);
	chomp($advice);
	if ($advice ne 'false') {
		# Native git-push would show this after the summary.
		# We can't ask it to display it cleanly, so print it
		# ourselves before.
		print {*STDERR} "To prevent you from losing history, non-fast-forward updates were rejected\n";
		print {*STDERR} "Merge the remote changes (e.g. 'git pull') before pushing again. See the\n";
		print {*STDERR} "'Note about fast-forwards' section of 'git push --help' for details.\n";
	}
	print {*STDOUT} qq(error $_[0] "non-fast-forward"\n);
	return 0;
}

# Classify a MediaWiki API error (by its DETAILS string) as a transient
# server-side failure worth retrying under a heavy bulk push: a DB hiccup or
# InnoDB deadlock, rate limit, replica lag, read-only window, 5xx, a dropped
# connection, or a stale CSRF/session token. MediaWiki surfaces several of
# these as edit code 3 -- indistinguishable from a genuine edit conflict -- so
# the classification is by string, not code. (Local fork change.)
sub is_transient_api_error {
	my $err_details = shift // q{};
	return $err_details =~ /DBQueryError|internal_api_error|ratelimited|maxlag|readonly|badtoken|assertuserfailed|assertbotfailed|Service.?Unavailable|HTTP.?50[0-9]|timed?.?out|Lost connection|Deadlock/i;
}

# A stale CSRF/session token (badtoken) or a dropped login (assert*failed) is
# only cured by REBUILDING the API handle -- a fresh login fetches a fresh
# token. connect_maybe() returns the SAME handle when one already exists, so a
# warm-handle reconnect would NOT refresh the token; only passing undef does.
# A plain network/DB blip needs no relogin, so reuse the warm handle there.
sub is_auth_transient {
	my $err_details = shift // q{};
	return $err_details =~ /badtoken|assertuserfailed|assertbotfailed|notloggedin|mustbeloggedin|session/i;
}

# Run one MediaWiki edit/upload/delete API call, retrying TRANSIENT server-side
# failures with escalating backoff instead of aborting the whole push. Returns
# the API result on success, or undef for a non-transient failure / exhausted
# retries (with $mediawiki->{error} still set, so the caller can classify it as
# skip / conflict / fatal). On an auth-class transient the handle is rebuilt to
# re-login and refresh the CSRF token. Shared by page edits and media uploads
# so both paths get identical resilience. (Local fork change.)
sub mw_api_edit_retry {
	my ($query, $opts, $what) = @_;
	my $attempt = 0;
	my $backoff = RETRY_BACKOFF_BASE;
	while (1) {
		my $result = $opts ? $mediawiki->edit($query, $opts)
				   : $mediawiki->edit($query);
		return $result if $result;
		my $err_details = $mediawiki->{error}->{details} || q{};
		# Honour remote.<remote>.maxRetries (default 3, 0 disables) -- the same
		# budget the fetch path uses -- instead of a hard-coded count, so a
		# no-retry configuration is respected on the push side too.
		if (!($attempt < $max_retries && is_transient_api_error($err_details))) {
			return;
		}
		$attempt++;
		print {*STDERR} "Transient error ${what} (attempt ${attempt}): ${err_details}; retrying...\n";
		# Exponential backoff capped at RETRY_BACKOFF_MAX, matching mw_retry.
		sleep($backoff);
		$backoff *= 2;
		$backoff = RETRY_BACKOFF_MAX if $backoff > RETRY_BACKOFF_MAX;
		if (is_auth_transient($err_details)) {
			$mediawiki = connect_maybe(undef, $remotename, $url);
		} else {
			$mediawiki = connect_maybe($mediawiki, $remotename, $url);
		}
	}
}

sub mw_upload_file {
	my $complete_file_name = shift;
	my $new_sha1 = shift;
	my $extension = shift;
	my $file_deleted = shift;
	my $summary = shift;
	my $newrevid;
	my $path = "File:${complete_file_name}";
	my %hashFiles = get_allowed_file_extensions();
	if (!exists($hashFiles{$extension})) {
		print {*STDERR} "${complete_file_name} is not a permitted file on this wiki.\n";
		print {*STDERR} "Check the configuration of file uploads in your mediawiki.\n";
		return $newrevid;
	}
	# Deleting and uploading a file requires a privileged user
	if ($file_deleted) {
		# A delete is wiki-mutating (and non-idempotent), so dry-run must skip it
		# too -- not just the upload branch below. (Local fork change.)
		if ($dry_run) {
			print {*STDERR} "DRY-RUN: would delete '${path}'; skipped.\n";
			return $newrevid;
		}
		$mediawiki = connect_maybe($mediawiki, $remotename, $url);
		my $query = {
			action => 'delete',
			title => $path,
			reason => $summary
		};
		if (!mw_api_edit_retry($query, undef, "deleting file '${path}'")) {
			print {*STDERR} "Failed to delete file on remote wiki\n";
			print {*STDERR} "Check your permissions on the remote site. Error code:\n";
			print {*STDERR} $mediawiki->{error}->{code} . ':' . $mediawiki->{error}->{details};
			exit 1;
		}
	} else {
		# Don't let perl try to interpret file content as UTF-8 => use "raw"
		my $content = run_git_quoted(["cat-file", "blob", $new_sha1], 'raw');
		if ($content ne EMPTY) {
			if ($dry_run) {
				print {*STDERR} "DRY-RUN: would upload '${complete_file_name}' (" . length($content) . " bytes); skipped.\n";
				return $newrevid;
			}
			$mediawiki = connect_maybe($mediawiki, $remotename, $url);
			$mediawiki->{config}->{upload_url} =
				"${url}/index.php/Special:Upload";
			my $uploaded = mw_api_edit_retry({
				action => 'upload',
				filename => $complete_file_name,
				comment => $summary,
				file => [undef,
					 $complete_file_name,
					 Content => $content],
				ignorewarnings => 1,
			}, {
				skip_encoding => 1
			}, "uploading '${complete_file_name}'" );
			if (!$uploaded) {
				my $err_code = $mediawiki->{error}->{code} // q{};
				my $err_details = $mediawiki->{error}->{details} // q{};
				# 'fileexists-no-change': the remote already holds the EXACT same
				# bytes, so the upload is a no-op rather than a failure. This shows
				# up on an idempotent re-push (a resumed/checkpointed push that
				# re-offers an already-uploaded file). Treat it as success and skip
				# instead of aborting the WHOLE push. (Local fork change.)
				if ($err_details =~ /fileexists-no-change/) {
					print {*STDERR} "File ${complete_file_name} already identical on remote; skipping.\n";
				} else {
					die $err_code . ':' . $err_details . "\n";
				}
			}
			my $last_file_page = $mediawiki->get_page({title => $path});
			$newrevid = $last_file_page->{revid};
			print {*STDERR} "Pushed file: ${new_sha1} - ${complete_file_name}.\n";
		} else {
			print {*STDERR} "Empty file ${complete_file_name} not pushed.\n";
		}
	}
	return $newrevid;
}

sub mw_push_file {
	my $diff_info = shift;
	# $diff_info contains a string in this format:
	# 100644 100644 <sha1_of_blob_before_commit> <sha1_of_blob_now> <status>
	my @diff_info_split = split(/[ \t]/, $diff_info);

	# Filename, including .mw extension
	my $complete_file_name = shift;
	# Commit message
	my $summary = shift;
	# MediaWiki revision number. Keep the previous one by default,
	# in case there's no edit to perform.
	my $oldrevid = shift;
	my $newrevid;

	if ($summary eq EMPTY_MESSAGE) {
		$summary = EMPTY;
	}

	my $new_sha1 = $diff_info_split[3];
	my $old_sha1 = $diff_info_split[2];
	my $page_created = ($old_sha1 eq NULL_SHA1);
	my $page_deleted = ($new_sha1 eq NULL_SHA1);
	$complete_file_name = clean_filename($complete_file_name);

	my ($title, $extension) = $complete_file_name =~ /^(.*)\.([^\.]*)$/;
	if (!defined($extension)) {
		$extension = EMPTY;
	}
	if ($extension eq 'mw') {
		my $ns = get_mw_namespace_id_for_page($complete_file_name);
		if ($ns && $ns == get_mw_namespace_id('File') && (!$export_media)) {
			print {*STDERR} "Ignoring media file related page: ${complete_file_name}\n";
			return ($oldrevid, 'ok');
		}
		# A privileged restore can truly delete a removed page (action=delete),
		# leaving it GONE rather than as a visible empty marker page. Opt-in via
		# remote.<remotename>.deletePages; mirrors mw_upload_file's file delete.
		# (Local fork change.)
		if ($page_deleted && $delete_pages) {
			if ($dry_run) {
				print {*STDERR} "DRY-RUN: would delete page '${title}'; skipped.\n";
				return ($oldrevid, 'ok');
			}
			$mediawiki = connect_maybe($mediawiki, $remotename, $url);
			my $deleted = mw_api_edit_retry({
				action => 'delete',
				title  => $title,
				reason => $summary,
			}, undef, "deleting page '${title}'");
			if (!$deleted) {
				my $err_details = $mediawiki->{error}->{details} || q{};
				my $err_code = $mediawiki->{error}->{code} // 0;
				# Already gone: the page does not exist on the remote (a re-push, or
				# never created). Nothing to delete -- treat as success, not an abort.
				if ($err_details =~ /missingtitle|cantdelete/) {
					print {*STDERR} "Page '${title}' already absent on remote; skipping delete.\n";
					return ($oldrevid, 'ok');
				}
				# Cannot delete this page (no delete right, or it is protected):
				# fall back to the marker convention rather than aborting the WHOLE
				# push, so a partially-privileged restore still round-trips the
				# deletion. Mirrors the protection/permission codes the marker edit
				# path below treats as skippable -- a page protected against the
				# marker edit too is then skipped there, leaving it untouched (the
				# pre-deletePages behaviour). A truly unknown error still dies.
				if ($err_details =~ /permissiondenied|badaccess|protectedpage|protectednamespace|cascadeprotected|namespaceprotected|protectedtitle/) {
					print {*STDERR} "Cannot delete '${title}' (${err_details}); falling back to deletion marker.\n";
				} else {
					die 'Fatal: Error ' . $err_code .
						' from mediawiki: ' . $err_details . "\n";
				}
			} else {
				print {*STDERR} "Deleted page: ${title}\n";
				return ($oldrevid, 'ok');
			}
		}

		my $file_content;
		if ($page_deleted) {
			# Deleting a page usually requires special privileges, so the convention
			# is to overwrite it with a marker instead -- one valid for the page's
			# content model (a wikitext marker in a css/js page is served literally
			# and breaks the site assets). is_deleted_marker() recognises it again on
			# import so the deletion round-trips. (Local fork change.)
			$file_content = deleted_content_for_title($title);
		} else {
			$file_content = run_git_quoted(["cat-file", "blob", $new_sha1]);
		}

		if ($dry_run) {
			print {*STDERR} "DRY-RUN: would push '${title}' (" . length($file_content) . " bytes); skipped.\n";
			return ($oldrevid, 'ok');
		}

		$mediawiki = connect_maybe($mediawiki, $remotename, $url);

		# basetimestamp omitted: it is an edit-conflict guard keyed on the REMOTE
		# wiki's own revision ids, only coherent when the local repo was cloned
		# from THIS wiki. When restoring a clone of a DIFFERENT wiki, $oldrevid
		# indexes an unrelated remote page and MediaWiki rejects every edit of an
		# already-existing page as a bogus conflict (code 3 -> aborts the whole
		# restore). Omitting it is last-write-wins, the correct semantics for a
		# one-directional content restore. (Local fork change.)
		# Transient server-side errors under a heavy bulk restore (DB hiccup /
		# deadlock, rate limit, replica lag, read-only, 5xx, lost connection,
		# stale token) are retried with backoff inside mw_api_edit_retry rather
		# than aborting the entire push; an auth-class transient there rebuilds
		# the handle to refresh the CSRF token. A non-transient failure returns
		# undef with $mediawiki->{error} set, classified below. (Local fork change.)
		my $edit_t0 = $profile ? Time::HiRes::time() : 0;
		my $result = mw_api_edit_retry({
			action => 'edit',
			summary => $summary,
			title => $title,
			text => mediawiki_clean($file_content, $page_created),
		}, {
			skip_encoding => 1 # Helps with names with accentuated characters
		}, "pushing '${title}'");
		if ($profile && $result) {
			my $dt = Time::HiRes::time() - $edit_t0;
			push @profile_samples, $dt;
			printf {*STDERR} "profile: edit '%s' %.3fs\n", $title, $dt;
		}
		if (!$result) {
			my $err_details = $mediawiki->{error}->{details} || q{};
			my $err_code = $mediawiki->{error}->{code} // 0;
			# A page that cannot be edited on THIS wiki (protected namespace /
			# protected page / protected site CSS-JS / missing permission) should
			# be SKIPPED, not treated as a conflict that aborts the whole push.
			# This is common when restoring a clone onto a wiki that locks some
			# namespaces (e.g. Talk) or site interface pages. (Local fork change.)
			if ($err_details =~ /protectednamespace|protectedpage|cascadeprotected|customcssprotected|customjsprotected|sitecssprotected|sitejsprotected|permissiondenied|protectedtitle|cantcreate|namespaceprotected/) {
				print {*STDERR} "Skipping '${title}' (not editable on this wiki): ${err_details}\n";
				return ($oldrevid, 'ok');
			}
			if ($err_code == 3) {
				# genuine edit conflict (or a transient that outlasted the
				# retries), considered as non-fast-forward
				print {*STDERR} 'Warning: Error ' . $err_code .
					' from mediawiki: ' . $err_details . ".\n";
				return ($oldrevid, 'non-fast-forward');
			} else {
				# Other errors. Shouldn't happen => just die()
				die 'Fatal: Error ' . $err_code .
					' from mediawiki: ' . $err_details . "\n";
			}
		}
		$newrevid = $result->{edit}->{newrevid};
		print {*STDERR} "Pushed file: ${new_sha1} - ${title}\n";
	} elsif ($export_media) {
		$newrevid = mw_upload_file($complete_file_name, $new_sha1,
															 $extension, $page_deleted,
															 $summary);
	} else {
		print {*STDERR} "Ignoring media file ${title}\n";
	}
	$newrevid = ($newrevid or $oldrevid);
	return ($newrevid, 'ok');
}

sub mw_push {
	# multiple push statements can follow each other
	my @refsspecs = (shift, get_more_refs('push'));
	my $pushed;
	for my $refspec (@refsspecs) {
		my ($force, $local, $remote) = $refspec =~ /^(\+)?([^:]*):([^:]*)$/
			or die("Invalid refspec for push. Expected <src>:<dst> or +<src>:<dst>\n");
		if ($force) {
			print {*STDERR} "Warning: forced push not allowed on a MediaWiki.\n";
		}
		if ($local eq EMPTY) {
			print {*STDERR} "Cannot delete remote branch on a MediaWiki\n";
			print {*STDOUT} "error ${remote} cannot delete\n";
			next;
		}
		if ($remote ne 'refs/heads/master') {
			print {*STDERR} "Only push to the branch 'master' is supported on a MediaWiki\n";
			print {*STDOUT} "error ${remote} only master allowed\n";
			next;
		}
		if (mw_push_revision($local, $remote)) {
			$pushed = 1;
		}
	}

	# Notify Git that the push is done
	print {*STDOUT} "\n";

	if ($pushed && $dumb_push) {
		print {*STDERR} "Just pushed some revisions to MediaWiki.\n";
		print {*STDERR} "The pushed revisions now have to be re-imported, and your current branch\n";
		print {*STDERR} "needs to be updated with these re-imported commits. You can do this with\n";
		print {*STDERR} "\n";
		print {*STDERR} "  git pull --rebase\n";
		print {*STDERR} "\n";
	}

	if ($profile && @profile_samples) {
		my $n = scalar(@profile_samples);
		my $total = 0;
		$total += $_ for @profile_samples;
		my @sorted = sort { $b <=> $a } @profile_samples;
		printf {*STDERR} "profile: %d edits, total %.1fs, mean %.3fs, median %.3fs, slowest %.3fs\n",
			$n, $total, $total / $n, $sorted[int($n / 2)], $sorted[0];
	}
	return;
}

# Resume support: given the ordered (oldest-first) [parent, child] commit-pair
# list a push is about to send and the child SHA recorded by a previous
# interrupted push's checkpoint, drop the commits already fully pushed
# (everything up to AND including the checkpoint commit) so the push continues
# where it left off. Returns the trimmed arrayref; if the checkpoint is empty or
# not on this push path (stale / a different HEAD), the list is returned
# unchanged. Pure -- no git, no network -- so it is unit-testable. (Local fork change.)
sub resume_trim_commit_pairs {
	my ($pairs, $checkpoint) = @_;
	return $pairs if !defined($checkpoint) || $checkpoint eq q{};
	for (my $i = 0; $i < scalar(@{$pairs}); $i++) {
		if ($pairs->[$i]->[1] eq $checkpoint) {
			return [ @{$pairs}[$i + 1 .. $#{$pairs}] ];
		}
	}
	return $pairs;
}

# True if commit $ancestor is an ancestor of (or equal to) commit $descendant.
# `git merge-base --is-ancestor` exits 0 (yes) / 1 (no) -- a normal result, not
# an error -- so it is run directly and the status checked, rather than via
# run_git_quoted (which dies on a non-zero exit). (Local fork change.)
sub git_is_ancestor {
	my ($ancestor, $descendant) = @_;
	return 0 if !defined($ancestor) || !defined($descendant)
		|| $ancestor eq q{} || $descendant eq q{};
	system('git', 'merge-base', '--is-ancestor', $ancestor, $descendant);
	return ($? == 0);
}

sub mw_push_revision {
	my $local = shift;
	my $remote = shift;						# actually, this has to be "refs/heads/master" at this point.
	my $last_local_revid = get_last_local_revision();
	print {*STDERR} ".\n";				# Finish sentence started by get_last_local_revision()
	my $last_remote_revid = get_last_remote_revision();
	my $mw_revision = $last_remote_revid;

	# Get sha1 of commit pointed by local HEAD
	my $HEAD_sha1 = run_git_quoted_nostderr(["rev-parse", $local]);
	chomp($HEAD_sha1);
	# Get sha1 of commit pointed by remotes/$remotename/master
	my $remoteorigin_sha1 = run_git_quoted_nostderr(["rev-parse", "refs/remotes/${remotename}/master"]);
	chomp($remoteorigin_sha1);

	# Read any resume checkpoint from a previous interrupted push BEFORE the
	# non-fast-forward guard below. A checkpoint that is an ancestor of HEAD means
	# the remote was advanced by OUR OWN interrupted push (whose tracking note did
	# not catch up) -- not by a genuine remote change -- so the remote being ahead
	# of $last_local_revid is expected and must NOT be rejected as non-fast-forward;
	# the trim further down then skips the commits already pushed. (Local fork change.)
	my $checkpoint_ref = "refs/mediawiki/${remotename}/push-checkpoint";
	my $checkpoint = q{};
	if ($push_resume) {
		# for-each-ref exits 0 whether or not the ref exists (empty when absent).
		$checkpoint = run_git_quoted(["for-each-ref", "--format=%(objectname)", $checkpoint_ref]);
		chomp($checkpoint);
	}
	my $resuming = ($checkpoint ne q{} && git_is_ancestor($checkpoint, $HEAD_sha1));

	if (!$resuming && $last_local_revid > 0 && $last_local_revid < $last_remote_revid) {
		return error_non_fast_forward($remote);
	}

	if ($HEAD_sha1 eq $remoteorigin_sha1) {
		# nothing to push
		return 0;
	}

	# Get every commit in between HEAD and refs/remotes/origin/master,
	# including HEAD and refs/remotes/origin/master
	my @commit_pairs = ();
	if ($last_local_revid > 0) {
		my $parsed_sha1 = $remoteorigin_sha1;
		# Find a path from last MediaWiki commit to pushed commit
		print {*STDERR} "Computing path from local to remote ...\n";
		my @local_ancestry = split(/\n/, run_git_quoted(["rev-list", "--boundary", "--parents", $local, "^${parsed_sha1}"]));
		my %local_ancestry;
		foreach my $line (@local_ancestry) {
			if (my ($child, $parents) = $line =~ /^-?([a-f0-9]+) ([a-f0-9 ]+)/) {
				foreach my $parent (split(/ /, $parents)) {
					$local_ancestry{$parent} = $child;
				}
			} elsif ($line !~ /^-?[a-f0-9]+/) {
				# Accept the leading '-' of a `--boundary` commit: when that
				# boundary commit is a ROOT (no parents) the first regex above
				# does not match, and the boundary line is just '-<sha>' with no
				# parents to record -- not malformed output. Only a line that is
				# not even an (optionally dash-prefixed) sha is unexpected.
				die "Unexpected output from git rev-list: ${line}\n";
			}
		}
		while ($parsed_sha1 ne $HEAD_sha1) {
			my $child = $local_ancestry{$parsed_sha1};
			if (!$child) {
				print {*STDERR} "Cannot find a path in history from remote commit to last commit\n";
				return error_non_fast_forward($remote);
			}
			push(@commit_pairs, [$parsed_sha1, $child]);
			$parsed_sha1 = $child;
		}
	} else {
		# No remote mediawiki revision. Export the whole
		# history (linearized with --first-parent)
		print {*STDERR} "Warning: no common ancestor, pushing complete history\n";
		my $history = run_git_quoted(["rev-list", "--first-parent", "--children", $local]);
		my @history = split(/\n/, $history);
		@history = @history[1..$#history];
		foreach my $line (reverse @history) {
			my @commit_info_split = split(/[ \n]/, $line);
			push(@commit_pairs, \@commit_info_split);
		}
		# BUGFIX (data loss): the root commit has no parent, so its pages never
		# appear in a (parent -> child) diff pair above and were silently
		# dropped. Diff each root against the empty tree so its additions get
		# pushed too. Processed first since the root is the oldest.
		my $empty_tree = run_git_quoted(["hash-object", "-t", "tree", "/dev/null"]);
		chomp($empty_tree);
		my @roots = split(/\n/, run_git_quoted(["rev-list", "--max-parents=0", "--first-parent", $local]));
		foreach my $root (reverse @roots) {
			chomp($root);
			unshift(@commit_pairs, [$empty_tree, $root]);
		}
	}

	# Resume an interrupted push: drop the commits already sent ($checkpoint and
	# $checkpoint_ref were read above, before the non-fast-forward guard).
	if ($push_resume && $checkpoint ne q{}) {
		my $before = scalar @commit_pairs;
		@commit_pairs = @{ resume_trim_commit_pairs(\@commit_pairs, $checkpoint) };
		my $skipped = $before - scalar(@commit_pairs);
		if ($skipped > 0) {
			print {*STDERR} "Resuming push after checkpoint ${checkpoint}: skipping ${skipped} already-pushed commit(s).\n";
		}
	}

	foreach my $commit_info_split (@commit_pairs) {
		my $sha1_child = @{$commit_info_split}[0];
		my $sha1_commit = @{$commit_info_split}[1];
		my $diff_infos = run_git_quoted(["diff-tree", "-r", "--raw", "-z", $sha1_child, $sha1_commit]);
		# TODO: we could detect rename, and encode them with a #redirect on the wiki.
		# TODO: for now, it's just a delete+add
		my @diff_info_list = split(/\0/, $diff_infos);
		# Keep the subject line of the commit message as mediawiki comment for the revision
		my $commit_msg = run_git_quoted(["log", "--no-walk", '--format="%s"', $sha1_commit]);
		chomp($commit_msg);
		# git diff-tree -z gives an output like
		# <metadata>\0<filename1>\0<metadata>\0<filename2>\0 (split on \0), so
		# collect the (metadata, filename) pairs for this commit first.
		my @file_pairs;
		while (@diff_info_list) {
			my $info = shift(@diff_info_list);
			my $file = shift(@diff_info_list);
			push @file_pairs, [$info, $file];
		}
		if ($parallel_push > 1 && $dumb_push && scalar(@file_pairs) > 1) {
			# Parallel sharded push -- dumbPush only (no per-page notes / ordering to
			# preserve; each page is an independent last-write-wins edit). Fork up to
			# $parallel_push workers, round-robin the files; each child RECONNECTS
			# (connect_maybe(undef,...)) because a forked API/LWP handle is not safe to
			# share. Children only edit the wiki + write STDERR -- never the git protocol
			# STDOUT -- so forking the remote helper here is safe. Exit 0=ok, 1=push error.
			my $workers = $parallel_push < scalar(@file_pairs) ? $parallel_push : scalar(@file_pairs);
			my @pids;
			for (my $w = 0; $w < $workers; $w++) {
				my $pid = fork();
				if (!defined $pid) {
					# fork exhaustion: reap the workers already started so they are
					# not orphaned, then fail the push (a dumbPush re-push is idempotent).
					waitpid($_, 0) for @pids;
					die "fork failed: $!\n";
				}
				if ($pid == 0) {
					$mediawiki = connect_maybe(undef, $remotename, $url);
					for (my $j = $w; $j < scalar(@file_pairs); $j += $workers) {
						my (undef, $cstatus) = mw_push_file($file_pairs[$j]->[0], $file_pairs[$j]->[1], $commit_msg, $mw_revision);
						exit 1 if $cstatus ne 'ok';
					}
					exit 0;
				}
				push @pids, $pid;
			}
			my $failed = 0;
			for my $pid (@pids) {
				waitpid($pid, 0);
				$failed = 1 if $? != 0;
			}
			# A child failure (non-fast-forward or fatal edit error) fails the push.
			return error_non_fast_forward($remote) if $failed;
		} else {
			# Serial push (default; required for an incremental, notes-tracked push so
			# $mw_revision advances in order for the tracking note written below).
			for my $pair (@file_pairs) {
				my $status;
				($mw_revision, $status) = mw_push_file($pair->[0], $pair->[1], $commit_msg, $mw_revision);
				if ($status eq 'non-fast-forward') {
					# we may already have sent part of the commit to MediaWiki, but
					# it's too late to cancel it. Stop the push in the middle, but
					# still give an accurate error message.
					return error_non_fast_forward($remote);
				}
				if ($status ne 'ok') {
					die("Unknown error from mw_push_file()\n");
				}
			}
		}
		# In dry-run NOTHING was actually pushed, so do NOT write the durable
		# mediawiki_revision tracking note nor advance the resume checkpoint --
		# that would falsely mark these pages as pushed for a later REAL push.
		if (!$dumb_push && !$dry_run) {
			run_git_quoted(["notes", "--ref=${remotename}/mediawiki",
					"add", "-f", "-m",
					"mediawiki_revision: ${mw_revision}",
					$sha1_commit]);
		}
		# Advance the resume checkpoint: this commit and all its files are now
		# fully pushed, so an interruption after this point resumes from here.
		if ($push_resume && !$dry_run) {
			run_git_quoted(["update-ref", $checkpoint_ref, $sha1_commit]);
		}
	}

	# Whole push succeeded -- git advances the remote-tracking ref via the "ok"
	# below, so the checkpoint is no longer needed; drop it (guarded so a
	# never-created checkpoint does not error). Skipped in dry-run, which created
	# no checkpoint and must not delete a real one left by a prior interrupted push.
	if ($push_resume && !$dry_run) {
		my $cp = run_git_quoted(["for-each-ref", "--format=%(objectname)", $checkpoint_ref]);
		chomp($cp);
		run_git_quoted(["update-ref", "-d", $checkpoint_ref]) if $cp ne q{};
	}

	print {*STDOUT} "ok ${remote}\n";
	return 1;
}

## The wiki's allowed file extensions do not change during a push, but
## mw_upload_file calls this once PER media file -- so on a media-heavy push it
## fired a redundant siteinfo round-trip for every binary (hundreds/thousands).
## Cache the result for the lifetime of the process. (Local fork change -- perf.)
my %allowed_file_extensions_cache;
my $allowed_file_extensions_cached = 0;
sub get_allowed_file_extensions {
	return %allowed_file_extensions_cache if $allowed_file_extensions_cached;

	$mediawiki = connect_maybe($mediawiki, $remotename, $url);

	my $query = {
		action => 'query',
		meta => 'siteinfo',
		siprop => 'fileextensions'
	};
	my $result = $mediawiki->api($query);
	my @file_extensions = map { $_->{ext}} @{$result->{query}->{fileextensions}};
	%allowed_file_extensions_cache = map { $_ => 1 } @file_extensions;
	$allowed_file_extensions_cached = 1;

	return %allowed_file_extensions_cache;
}

# In memory cache for MediaWiki namespace ids.
my %namespace_id;

# Namespaces whose id is cached in the configuration file
# (to avoid duplicates)
my %cached_mw_namespace_id;

# Return MediaWiki id for a canonical namespace name.
# Ex.: "File", "Project".
sub get_mw_namespace_id {
	$mediawiki = connect_maybe($mediawiki, $remotename, $url);
	my $name = shift;

	if (!exists $namespace_id{$name}) {
		# Look at configuration file, if the record for that namespace is
		# already cached. Namespaces are stored in form:
		# "Name_of_namespace:Id_namespace", ex.: "File:6".
		my @temp = split(/\n/,
				 run_git_quoted(["config", "--get-all", "remote.${remotename}.namespaceCache"]));
		chomp(@temp);
		foreach my $ns (@temp) {
			my ($n, $id) = split(/:/, $ns);
			if ($id eq 'notANameSpace') {
				$namespace_id{$n} = {is_namespace => 0};
			} else {
				$namespace_id{$n} = {is_namespace => 1, id => $id};
			}
			$cached_mw_namespace_id{$n} = 1;
		}
	}

	if (!exists $namespace_id{$name}) {
		print {*STDERR} "Namespace ${name} not found in cache, querying the wiki ...\n";
		# NS not found => get namespace id from MW and store it in
		# configuration file.
		my $query = {
			action => 'query',
			meta => 'siteinfo',
			siprop => 'namespaces'
		};
		my $result = $mediawiki->api($query);

		while (my ($id, $ns) = each(%{$result->{query}->{namespaces}})) {
			if (defined($ns->{id}) && defined($ns->{canonical})) {
				$namespace_id{$ns->{canonical}} = {is_namespace => 1, id => $ns->{id}};
				if ($ns->{'*'}) {
					# alias (e.g. french Fichier: as alias for canonical File:)
					$namespace_id{$ns->{'*'}} = {is_namespace => 1, id => $ns->{id}};
				}
			}
	        }
	}

	my $ns = $namespace_id{$name};
	my $id;

	if (!defined $ns) {
		my @namespaces;
		for (sort keys %namespace_id) {
			s/ /_/g;
			push @namespaces, $_;
		}
		print {*STDERR} "No such namespace ${name} on MediaWiki, known namespaces: @namespaces\n";
		$ns = {is_namespace => 0};
		$namespace_id{$name} = $ns;
	}

	if ($ns->{is_namespace}) {
		$id = $ns->{id};
	}

	# Store "notANameSpace" as special value for inexisting namespaces
	my $store_id = ($id || 'notANameSpace');

	# Store explicitly requested namespaces on disk
	if (!exists $cached_mw_namespace_id{$name}) {
		run_git_quoted(["config", "--add", "remote.${remotename}.namespaceCache", "${name}:${store_id}"]);
		$cached_mw_namespace_id{$name} = 1;
	}
	return $id;
}

sub get_mw_namespace_id_for_page {
	my $page = shift;
	if ($page =~ /^([^:]*):/) {
		my $namespace = $1;
		return get_mw_namespace_id($namespace);
	} else {
		return;
	}
}
